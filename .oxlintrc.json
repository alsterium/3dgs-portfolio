{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "oxc"],
  "env": {
    "browser": true,
    "es2024": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-unused-vars": "error",
    "react/react-in-jsx-scope": "off",
    "no-underscore-dangle": "off"
  },
  "ignorePatterns": ["dist", "node_modules", "public"]
}
